red in OC-ATOM-SPACE-QUERY :
  source(member(concept("cat"), concept("animals"))) .
*** expect: concept("cat")

red in OC-ATOM-SPACE-QUERY :
  target(member(concept("cat"), concept("animals"))) .
*** expect: concept("animals")

red in OC-ATOM-SPACE-QUERY :
  ocArity(equivalence(concept("a"), concept("b"))) .
*** expect: 2

red in OC-ATOM-SPACE-QUERY :
  ocArity(similarity(concept("a"), concept("b"))) .
*** expect: 2

red in OC-ATOM-SPACE-QUERY :
  ocArity(member(concept("a"), concept("b"))) .
*** expect: 2

red in OC-ATOM-SPACE-QUERY :
  source(subset(concept("cats"), concept("animals"))) .
*** expect: concept("cats")

red in OC-ATOM-SPACE-QUERY :
  target(subset(concept("cats"), concept("animals"))) .
*** expect: concept("animals")

*** =================================================================
*** PLN FORMULAS: plnInduction, plnAbduction, plnSim2Inh, edge cases
*** =================================================================

load pln.maude

red in OC-PLN-FORMULAS : plnInduction(0.8, 0.9, 0.7, 0.8, 0.6, 0.5, 0.4) .

red in OC-PLN-FORMULAS : plnAbduction(0.7, 0.8, 0.6, 0.7, 0.5, 0.4, 0.6) .

red in OC-PLN-FORMULAS : plnSim2Inh(0.8, 0.9, 0.5, 0.5) .

red in OC-PLN-FORMULAS : plnAndIntro(1.0, 0.9, 1.0, 0.8) .
*** expect: stv(1.0, 0.8)

red in OC-PLN-FORMULAS : plnAndIntro(0.0, 0.9, 0.8, 0.7) .
*** expect: stv(0.0, 0.7)

red in OC-PLN-FORMULAS : plnOrIntro(0.0, 0.9, 0.0, 0.7) .
*** expect: stv(0.0, 0.7)

red in OC-PLN-FORMULAS : plnNotIntro(0.0, 0.9) .
*** expect: stv(1.0, 0.9)

red in OC-PLN-FORMULAS : plnNotIntro(1.0, 0.9) .
*** expect: stv(0.0, 0.9)

*** =================================================================
*** PLN RULES: induction, sim2inh, inh2member searches
*** =================================================================

*** Induction: poodle→dog, poodle→fluffy  ⊢  dog→fluffy
search [1] in OC-PLN-RULES :
  [concept("poodle"), stv(0.6, 0.8), defaultAV]
  [concept("dog"), stv(0.5, 0.7), defaultAV]
  [concept("fluffy"), stv(0.4, 0.6), defaultAV]
  [inheritance(concept("poodle"), concept("dog")), stv(0.9, 0.8), defaultAV]
  [inheritance(concept("poodle"), concept("fluffy")), stv(0.7, 0.6), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS:AtomSpace, inheritance(concept("dog"), concept("fluffy"))) == true .

*** Similarity-to-Inheritance
search [1] in OC-PLN-RULES :
  [concept("human"), stv(0.5, 0.8), defaultAV]
  [concept("person"), stv(0.5, 0.8), defaultAV]
  [similarity(concept("human"), concept("person")), stv(0.95, 0.9), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS:AtomSpace, inheritance(concept("human"), concept("person"))) == true .

*** Inheritance-to-Member
search [1] in OC-PLN-RULES :
  [inheritance(concept("fido"), concept("dog")), stv(0.9, 0.8), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS:AtomSpace, member(concept("fido"), concept("dog"))) == true .

*** =================================================================
*** ECAN: config accessors and rewrite rule searches
*** =================================================================

load ecan.maude

red in OC-ECAN-CONFIG : afBoundary(defaultECANParams) .
*** expect: 100

red in OC-ECAN-CONFIG : maxSTI(defaultECANParams) .
*** expect: 32767

red in OC-ECAN-CONFIG : spreadFraction(defaultECANParams) .
*** expect: 0.1

red in OC-ECAN-CONFIG : hebbianDecay(defaultECANParams) .
*** expect: 0.05

red in OC-ECAN-CONFIG : rentRate(defaultECANParams) .
*** expect: 0.01

red in OC-ECAN-CONFIG : forgettingThreshold(defaultECANParams) .
*** expect: -400

*** Stimulation: STI increases by 50
search [1] in OC-ECAN :
  [concept("cat"), stv(0.8, 0.9), av(100, 50, false)]
=>+ AS:AtomSpace
such that
  getAV(AS, concept("cat")) == av(150, 50, false) .

*** Rent collection: STI decreases by 1 when STI > 0 and not VLTI
search [1] in OC-ECAN :
  [concept("cat"), stv(0.8, 0.9), av(10, 50, false)]
=>+ AS:AtomSpace
such that
  getSTI(getAV(AS, concept("cat"))) == 9 .

*** Forgetting: atom removed when STI < -400 and not VLTI
search [1] in OC-ECAN :
  [concept("old-idea"), stv(0.5, 0.5), av(-500, 0, false)]
=>+ AS:AtomSpace
such that
  hasAtom(AS, concept("old-idea")) == false .

*** Asymmetric Hebbian spreading: source loses STI, target gains
search [1] in OC-ECAN :
  [asymHebbian(concept("cat"), concept("animal")), stv(0.8, 0.9), defaultAV]
  [concept("cat"), stv(1.0, 0.9), av(200, 50, false)]
  [concept("animal"), stv(1.0, 0.9), av(10, 50, false)]
=>+ AS:AtomSpace
such that
  getSTI(getAV(AS, concept("animal"))) > 10 .

*** LTI update: atom in attentional focus (STI > 100) gains LTI
search [1] in OC-ECAN :
  [concept("important"), stv(0.8, 0.9), av(200, 0, false)]
=>+ AS:AtomSpace
such that
  getLTI(getAV(AS, concept("important"))) == 1 .

*** =================================================================
*** COMBO: additional simplification and evaluation tests
*** =================================================================

load moses.maude

red in OC-COMBO : comboMinus(arithVar(0), comboNum(0.0)) .
*** expect: arithVar(0)

red in OC-COMBO : comboDiv(comboNum(6.0), comboNum(3.0)) .
*** expect: comboNum(2.0)

red in OC-COMBO : comboIf(comboFalse, comboNum(1.0), comboNum(0.0)) .
*** expect: comboNum(0.0)

red in OC-COMBO : comboAnd(boolVar(0), boolVar(0)) .
*** expect: boolVar(0)

red in OC-COMBO : comboOr(boolVar(0), boolVar(0)) .
*** expect: boolVar(0)

red in OC-COMBO-EVAL :
  evalBool(comboGT(arithVar(0), arithVar(1)),
           (0 ==> 5.0) ; (1 ==> 3.0)) .
*** expect: true

red in OC-COMBO-EVAL :
  evalBool(comboLT(arithVar(0), arithVar(1)),
           (0 ==> 2.0) ; (1 ==> 3.0)) .
*** expect: true

red in OC-COMBO-EVAL :
  evalBool(comboEQ(arithVar(0), arithVar(1)),
           (0 ==> 3.0) ; (1 ==> 3.0)) .
*** expect: true

red in OC-COMBO-EVAL :
  evalBool(comboEQ(arithVar(0), arithVar(1)),
           (0 ==> 3.0) ; (1 ==> 4.0)) .
*** expect: false

red in OC-COMBO-EVAL :
  evalArith(comboAbs(arithVar(0)), (0 ==> -5.0)) .
*** expect: 5.0

red in OC-COMBO-EVAL :
  evalArith(comboMinus(arithVar(0), arithVar(1)),
            (0 ==> 7.0) ; (1 ==> 3.0)) .
*** expect: 4.0

red in OC-COMBO-EVAL :
  evalArith(comboDiv(arithVar(0), arithVar(1)),
            (0 ==> 10.0) ; (1 ==> 2.0)) .
*** expect: 5.0

*** =================================================================
*** MOSES KNOBS AND POPULATION
*** =================================================================

red in OC-MOSES-KNOBS : knobCount(noKnobs) .
*** expect: 0

red in OC-MOSES-KNOBS :
  knobCount(
    boolKnob(0, 1) :: arithKnob(1, 0.5) :: discKnob(2, 0, 5) :: noKnobs
  ) .
*** expect: 3

red in OC-MOSES-POPULATION : demeSize(emptyDeme) .
*** expect: 0

red in OC-MOSES-POPULATION : bestScore(emptyDeme) .
*** expect: -1.0e10

*** Mutation: And → Or
search [1] in OC-MOSES-EVOLVE :
  scored(comboAnd(boolVar(0), boolVar(1)), 0.8)
=>+ SP:ScoredProgram
such that SP:ScoredProgram == scored(comboOr(boolVar(0), boolVar(1)), 0.0) .

*** Mutation: remove double negation
search [1] in OC-MOSES-EVOLVE :
  scored(comboNot(boolVar(0)), 0.5)
=>+ SP:ScoredProgram
such that SP:ScoredProgram == scored(boolVar(0), 0.0) .

*** =================================================================
*** URE RULE BASE: accessors and rule modification
*** =================================================================

load ure.maude

red in OC-URE-RULE-BASE : ruleName(urRule("deduction", 1.0, "pln-deduction")) .
*** expect: "deduction"

red in OC-URE-RULE-BASE : ruleWeight(urRule("deduction", 1.0, "pln-deduction")) .
*** expect: 1.0

red in OC-URE-RULE-BASE : ruleLabel(urRule("deduction", 1.0, "pln-deduction")) .
*** expect: "pln-deduction"

red in OC-URE-RULE-BASE : totalWeight(emptyRB) .
*** expect: 0.0

red in OC-URE-RULE-BASE :
  ruleCount(
    addRule(
      urRule("deduction", 1.0, "pln-deduction"),
      urRule("modus-ponens", 0.8, "pln-modus-ponens")
    )
  ) .
*** expect: 2

red in OC-URE-RULE-BASE :
  ruleCount(
    removeRule(
      urRule("deduction", 1.0, "pln-deduction") ;;
      urRule("modus-ponens", 0.8, "pln-modus-ponens"),
      "deduction"
    )
  ) .
*** expect: 1

*** =================================================================
*** COGSERVER AND FC STATE ACCESSORS
*** =================================================================

red in OPENCOG : csAS(newCogServer(emptyAS)) .
*** expect: emptyAS

red in OPENCOG : csCycle(newCogServer(emptyAS)) .
*** expect: 0

red in OPENCOG :
  fcMaxIter(fcState(emptyAS, defaultPLNRuleBase, 10, 0, concept("cat"))) .
*** expect: 10

red in OPENCOG :
  fcCurIter(fcState(emptyAS, defaultPLNRuleBase, 10, 0, concept("cat"))) .
*** expect: 0

red in OPENCOG :
  fcSource(fcState(emptyAS, defaultPLNRuleBase, 10, 0, concept("cat"))) .
*** expect: concept("cat")

*** CogServer cycle rotation
search [1] in OC-COG-SERVER :
  cogServer(emptyAS, plnAgent -> ecanAgent -> mosesAgent, emptyRB, 0)
=>+ CS:CogServerState
such that csCycle(CS:CogServerState) == 1 .

*** Forward chaining: modus ponens derives concept("flood")
search [1] in OC-URE-FORWARD-CHAINER :
  fcState(
    [concept("rain"), stv(0.9, 0.85), defaultAV]
    [implication(concept("rain"), concept("flood")), stv(0.8, 0.9), defaultAV],
    urRule("modus-ponens", 0.8, "pln-modus-ponens"),
    5, 0, concept("rain"))
=>+ FC:FCState
such that hasAtom(fcAS(FC:FCState), concept("flood")) == true .

*** =================================================================
*** PATTERN MATCHER: additional substitution cases
*** =================================================================

*** Substituting into a member link
red in OC-PATTERN-MATCHER :
  applySubst(
    member(variable("X"), concept("animals")),
    variable("X") |-> concept("cat")
  ) .
*** expect: member(concept("cat"), concept("animals"))

*** Substituting into similarity link
red in OC-PATTERN-MATCHER :
  applySubst(
    similarity(variable("A"), variable("B")),
    (variable("A") |-> concept("cat")) +
    (variable("B") |-> concept("tiger"))
  ) .
*** expect: similarity(concept("cat"), concept("tiger"))

*** Variable not in substitution is left unchanged
red in OC-PATTERN-MATCHER :
  applySubst(variable("Z"), variable("X") |-> concept("cat")) .
*** expect: variable("Z")

*** Ground atom is unchanged by any substitution
red in OC-PATTERN-MATCHER :
  applySubst(concept("cat"), variable("X") |-> concept("dog")) .
*** expect: concept("cat")

*** =================================================================
*** GRAPH PATTERN MATCHING: MeetLink and SatisfactionLink searches
*** =================================================================

load pattern-matcher.maude

*** MeetLink: produces setLink containing the matched ground atom
search [1] in OC-GRAPH-MATCH :
  [meet((variable("X"), nil),
        inheritance(variable("X"), concept("animal"))),
   stv(1.0, 0.9), defaultAV]
  [inheritance(concept("cat"), concept("animal")), stv(0.9, 0.8), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS, setLink(inheritance(concept("cat"), concept("animal")))) == true .

*** SatisfactionLink: truth value updated to stv(1.0, 1.0) when match exists
search [1] in OC-GRAPH-MATCH :
  [satisfaction((variable("X"), nil),
                inheritance(variable("X"), concept("animal"))),
   stv(0.5, 0.5), defaultAV]
  [inheritance(concept("dog"), concept("animal")), stv(0.8, 0.7), defaultAV]
=>+ AS:AtomSpace
such that
  tvStrength(getTV(AS,
    satisfaction((variable("X"), nil),
                 inheritance(variable("X"), concept("animal"))))) == 1.0 .

