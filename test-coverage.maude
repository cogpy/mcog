*** PATTERN MINER: accessors, support counting, seed generators
*** =================================================================

load pattern-miner.maude

*** MinedPattern accessors
red in OC-PATTERN-REP :
  mpSupport(minedPat(inheritance(variable("$X"), variable("$Y")), 5, 0.2)) .
*** expect: 5

red in OC-PATTERN-REP :
  mpSurprise(minedPat(inheritance(variable("$X"), variable("$Y")), 5, 0.2)) .
*** expect: 0.2

*** MinerConfig accessors
red in OC-PATTERN-REP : minSupport(defaultMinerConfig) .
*** expect: 5

red in OC-PATTERN-REP : maxPatSize(defaultMinerConfig) .
*** expect: 4

red in OC-PATTERN-REP : maxPatterns(defaultMinerConfig) .
*** expect: 100

red in OC-PATTERN-REP : minSurprise(defaultMinerConfig) .
*** expect: 0.1

*** isInstance: should succeed when pattern unifies with ground atom
red in OC-SUPPORT-COUNT :
  isInstance(inheritance(variable("$X"), concept("animal")),
             inheritance(concept("cat"), concept("animal"))) .
*** expect: true

*** isInstance: should fail when ground atoms differ
red in OC-SUPPORT-COUNT :
  isInstance(inheritance(variable("$X"), concept("animal")),
             inheritance(concept("cat"), concept("dog"))) .
*** expect: false

*** countSupport: two inheritance-to-animal links should score 2
red in OC-SUPPORT-COUNT :
  countSupport(
    inheritance(variable("$X"), concept("animal")),
    [inheritance(concept("cat"), concept("animal")), stv(0.9, 0.8), defaultAV]
    [inheritance(concept("dog"), concept("animal")), stv(0.8, 0.7), defaultAV]
    [inheritance(concept("fish"), concept("aquatic")), stv(0.7, 0.6), defaultAV]
  ) .
*** expect: 2

*** countSupport: no match returns 0
red in OC-SUPPORT-COUNT :
  countSupport(
    inheritance(variable("$X"), concept("reptile")),
    [inheritance(concept("cat"), concept("animal")), stv(0.9, 0.8), defaultAV]
  ) .
*** expect: 0

*** Seed pattern generators
red in OC-PATTERN-GEN : genInhSeed .
*** expect: inheritance(variable("$X"), variable("$Y"))

red in OC-PATTERN-GEN : genImplSeed .
*** expect: implication(variable("$X"), variable("$Y"))

red in OC-PATTERN-GEN : genMemberSeed .
*** expect: member(variable("$X"), variable("$Y"))

red in OC-PATTERN-GEN : genInhSeedFrom(concept("animal")) .
*** expect: inheritance(concept("animal"), variable("$Y"))

red in OC-PATTERN-GEN : genInhSeedTo(concept("animal")) .
*** expect: inheritance(variable("$X"), concept("animal"))

