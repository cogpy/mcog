***( ================================================================
***  OpenCog in Pure Maude — Comprehensive Coverage Test Suite
***
***  Covers areas missing from test-opencog.maude and
***  test-new-modules.maude:
***    - CountTruthValue / IndefiniteTruthValue / nullTV
***    - clamp01, countToConf/confToCount, tvRevision
***    - Attention value: decSTI, incLTI, decLTI, getLTI, getVLTI, nullAV
***    - AtomSpace: removeAtom, setTV, setAV, getAV, ocSize(emptyAS)
***    - AtomSpace Query: more getOutgoing / source / target / ocArity
***    - PLN: plnInduction, plnAbduction, plnSim2Inh; induction/sim2inh/
***           inh2member rewrite searches
***    - ECAN: all config accessors; spreading, rent, forgetting,
***            Hebbian, stimulation, LTI rewrite searches
***    - COMBO: comboMinus, comboDiv, comboGT/LT/EQ, comboAbs
***    - COMBO eval: GT/LT/EQ, Abs, Minus, Div
***    - MOSES knobs; demeSize(emptyDeme); mutation rewrite searches
***    - URE: ruleName/Weight/Label, addRule, removeRule, totalWeight(emptyRB)
***          FCState accessors; FC modus-ponens search; CogServer accessors;
***          cog-cycle search
***    - Pattern matcher: identity/ground substitutions
***    - Graph match: MeetLink search, SatisfactionLink search
***    - Pattern miner: all accessors; isInstance; countSupport;
***                     seed generators; patSize; iSurprise
***    - Spacetime: 6 remaining Allen relations; all allenInverse cases;
***                 start/end/tpVal; getInterval; temporal searches;
***                 spatial: getX/Y/Z, bboxMin/Max, isNear
***    - Ghost/Psi: demandTarget, modName/Level, prName/Context/Action/
***                 Demand/Weight, grName/Pattern, rulesForDemand edge cases;
***                 psiCycle; demand-increase search; ghost-gambit search
***    - Meta: isOrderedLink, isUnorderedLink, isEvaluatable, countNodes/
***            countLinks(emptyAS), stepName/Weight, all strategies,
***            rarName/rarAttempts, successRate(0,0), recordSuccess/Attempt,
***            typeCount(emptyDTR), register-type search
***    - Lambda/BetaReduce: member/evaluation/andLink isFreeIn;
***                          subset/member betaSubst
***    - ArithEval: numVal, evalArithAtom(number/minus/divide)
***    - ExecutionEngine: sequential execution search
*** ================================================================ )

set show timing off .
set show advisories off .

*** =================================================================
*** TRUTH VALUE: CountTruthValue and IndefiniteTruthValue
*** =================================================================

load truth-value.maude

red in OC-TRUTH-VALUE : tvStrength(ctv(0.7, 0.8, 100.0)) .
*** expect: 0.7

red in OC-TRUTH-VALUE : tvConfidence(ctv(0.7, 0.8, 100.0)) .
*** expect: 0.8

red in OC-TRUTH-VALUE : tvCount(ctv(0.7, 0.8, 100.0)) .
*** expect: 100.0

red in OC-TRUTH-VALUE : tvStrength(itv(0.4, 0.8, 0.7)) .
*** expect: 0.6

red in OC-TRUTH-VALUE : tvConfidence(itv(0.4, 0.8, 0.7)) .
*** expect: 0.7

red in OC-TRUTH-VALUE : tvStrength(nullTV) .
*** expect: 0.0

red in OC-TRUTH-VALUE : tvConfidence(nullTV) .
*** expect: 0.0

red in OC-TRUTH-VALUE : tvCount(nullTV) .
*** expect: 0.0

red in OC-TRUTH-VALUE : tvNegate(nullTV) .
*** expect: nullTV

*** clamp01 edge cases
red in OC-TRUTH-VALUE : clamp01(-0.5) .
*** expect: 0.0

red in OC-TRUTH-VALUE : clamp01(1.5) .
*** expect: 1.0

red in OC-TRUTH-VALUE : clamp01(0.5) .
*** expect: 0.5

*** count/confidence round-trip
red in OC-TRUTH-VALUE : countToConf(confToCount(0.5)) .
*** expect: 0.5

*** tvRevision: symmetric inputs should average strength
red in OC-TRUTH-VALUE : tvStrength(tvRevision(stv(0.8, 0.9), stv(0.2, 0.9))) .
*** expect: 0.5

*** tvAnd: confidence tracks the weaker source
red in OC-TRUTH-VALUE : tvAnd(stv(1.0, 0.9), stv(1.0, 0.7)) .
*** expect: stv(1.0, 0.7)

*** tvOr: both false stays 0
red in OC-TRUTH-VALUE : tvOr(stv(0.0, 0.9), stv(0.0, 0.7)) .
*** expect: stv(0.0, 0.7)

*** =================================================================
*** ATTENTION VALUE: additional accessors and operations
