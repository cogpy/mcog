load meta-opencog.maude

red in OC-TYPE-INTROSPECT : isOrderedLink(inheritance(concept("a"), concept("b"))) .
*** expect: true

red in OC-TYPE-INTROSPECT : isOrderedLink(equivalence(concept("a"), concept("b"))) .
*** expect: false

red in OC-TYPE-INTROSPECT : isUnorderedLink(similarity(concept("a"), concept("b"))) .
*** expect: true

red in OC-TYPE-INTROSPECT : isUnorderedLink(inheritance(concept("a"), concept("b"))) .
*** expect: false

red in OC-TYPE-INTROSPECT : isEvaluatable(evaluation(predicate("p"), nil)) .
*** expect: true

red in OC-TYPE-INTROSPECT : isEvaluatable(inheritance(concept("a"), concept("b"))) .
*** expect: false

red in OC-TYPE-INTROSPECT : countNodes(emptyAS) .
*** expect: 0

red in OC-TYPE-INTROSPECT : countLinks(emptyAS) .
*** expect: 0

