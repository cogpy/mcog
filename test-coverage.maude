*** Self-modification: empty registry
red in OC-SELF-MODIFY : typeCount(emptyDTR) .
*** expect: 0

red in OC-SELF-MODIFY : hasType(emptyDTR, "NonExistentType") .
*** expect: false

*** register-type rewrite rule
search [1] in OC-SELF-MODIFY :
  selfModState(
    [defineLink(typeNode("MyNode"), typeNode("ConceptNode")), stv(1.0, 0.9), defaultAV],
    emptyDTR,
    emptyARS,
    0)
=>+ SMS:SelfModState
such that hasType(smTypes(SMS:SelfModState), "MyNode") == true .

*** =================================================================
*** LAMBDA / BETA-REDUCE: additional free-variable and substitution cases
*** =================================================================

load execution-engine.maude

red in OC-LAMBDA :
  isFreeIn(variable("X"), member(variable("X"), concept("animals"))) .
*** expect: true

red in OC-LAMBDA :
  isFreeIn(variable("X"), member(concept("cat"), concept("animals"))) .
*** expect: false

red in OC-LAMBDA :
  isFreeIn(variable("X"), evaluation(variable("X"), nil)) .
*** expect: true

red in OC-LAMBDA :
  isFreeIn(variable("X"), andLink((variable("X"), concept("a"), nil))) .
*** expect: true

red in OC-BETA-REDUCE :
  betaSubst(member(variable("X"), concept("animals")),
            variable("X"), concept("cat")) .
*** expect: member(concept("cat"), concept("animals"))

red in OC-BETA-REDUCE :
  betaSubst(subset(variable("X"), concept("B")),
            variable("X"), concept("A")) .
*** expect: subset(concept("A"), concept("B"))

*** =================================================================
*** ARITHMETIC EVALUATION: numVal, evalArithAtom
*** =================================================================

red in OC-ARITH-EVAL : numVal(number("5")) .
*** expect: 5.0

red in OC-ARITH-EVAL : numVal(number("0")) .
*** expect: 0.0

red in OC-ARITH-EVAL : numVal(number("-1")) .
*** expect: -1.0

*** evalArithAtom on a plain NumberNode is identity
red in OC-ARITH-EVAL : evalArithAtom(number("7")) .
*** expect: number("7")

*** evalArithAtom: 10 - 3 = 7
red in OC-ARITH-EVAL : evalArithAtom(minusLink(number("10"), number("3"))) .
*** expect: number("7")

*** evalArithAtom: 10 / 2 = 5
red in OC-ARITH-EVAL : evalArithAtom(divideLink(number("10"), number("2"))) .
*** expect: number("5")

*** =================================================================
*** EXECUTION ENGINE: sequential execution search
*** =================================================================

*** SequentialAnd splits into its first step (reachable from search)
search [1] in OC-EXECUTION-ENGINE :
  [seqAnd((concept("step1"), concept("step2"), nil)), stv(1.0, 0.9), defaultAV]
=>+ AS:AtomSpace
such that hasAtom(AS, concept("step1")) == true .

