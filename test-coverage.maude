load spacetime.maude

*** Remaining Allen relations
red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(5), tp(9)), interval(tp(1), tp(5))) .
*** expect: metBy

red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(4), tp(9)), interval(tp(1), tp(6))) .
*** expect: overlappedBy

red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(1), tp(5)), interval(tp(1), tp(9))) .
*** expect: starts

red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(1), tp(9)), interval(tp(1), tp(5))) .
*** expect: startedBy

red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(3), tp(9)), interval(tp(1), tp(9))) .
*** expect: finishes

red in OC-ALLEN-INTERVALS :
  allenRelation(interval(tp(1), tp(9)), interval(tp(3), tp(9))) .
*** expect: finishedBy

*** allenInverse: complete coverage of all 13 relations
red in OC-ALLEN-INTERVALS : allenInverse(before) .
*** expect: after

red in OC-ALLEN-INTERVALS : allenInverse(after) .
*** expect: before

red in OC-ALLEN-INTERVALS : allenInverse(meets) .
*** expect: metBy

red in OC-ALLEN-INTERVALS : allenInverse(metBy) .
*** expect: meets

red in OC-ALLEN-INTERVALS : allenInverse(overlaps) .
*** expect: overlappedBy

red in OC-ALLEN-INTERVALS : allenInverse(overlappedBy) .
*** expect: overlaps

red in OC-ALLEN-INTERVALS : allenInverse(starts) .
*** expect: startedBy

red in OC-ALLEN-INTERVALS : allenInverse(startedBy) .
*** expect: starts

red in OC-ALLEN-INTERVALS : allenInverse(during) .
*** expect: contains

red in OC-ALLEN-INTERVALS : allenInverse(contains) .
*** expect: during

red in OC-ALLEN-INTERVALS : allenInverse(finishes) .
*** expect: finishedBy

red in OC-ALLEN-INTERVALS : allenInverse(finishedBy) .
*** expect: finishes

red in OC-ALLEN-INTERVALS : allenInverse(equals) .
*** expect: equals

*** Interval accessors
red in OC-ALLEN-INTERVALS : start(interval(tp(3), tp(10))) .
*** expect: tp(3)

red in OC-ALLEN-INTERVALS : end(interval(tp(3), tp(10))) .
*** expect: tp(10)

red in OC-ALLEN-INTERVALS : tpVal(tp(42)) .
*** expect: 42

*** TimeServer: getInterval round-trip
red in OC-TIME-SERVER :
  getInterval(
    addTemporal(timeServer(emptyTM, 100), concept("event1"), interval(tp(10), tp(20))),
    concept("event1")
  ) .
*** expect: interval(tp(10), tp(20))

red in OC-TIME-SERVER : tsNow(timeServer(emptyTM, 42)) .
*** expect: 42

*** Spatial: 3D point and bounding box accessors
red in OC-SPATIAL : getX(point3d(1.0, 2.0, 3.0)) .
*** expect: 1.0

red in OC-SPATIAL : getY(point3d(1.0, 2.0, 3.0)) .
*** expect: 2.0

red in OC-SPATIAL : getZ(point3d(1.0, 2.0, 3.0)) .
*** expect: 3.0

red in OC-SPATIAL :
  bboxMin(bbox(point3d(0.0, 0.0, 0.0), point3d(1.0, 1.0, 1.0))) .
*** expect: point3d(0.0, 0.0, 0.0)

red in OC-SPATIAL :
  bboxMax(bbox(point3d(0.0, 0.0, 0.0), point3d(1.0, 1.0, 1.0))) .
*** expect: point3d(1.0, 1.0, 1.0)

red in OC-SPATIAL :
  isNear(point3d(0.0, 0.0, 0.0), point3d(0.5, 0.0, 0.0), 1.0) .
*** expect: true

red in OC-SPATIAL :
  isNear(point3d(0.0, 0.0, 0.0), point3d(5.0, 5.0, 5.0), 1.0) .
*** expect: false

*** Temporal overlap: creates attraction link
search [1] in OC-TEMPORAL-REASONING :
  [atTimeLink(concept("A"), timeIntervalNode(1, 6)), stv(0.9, 0.8), defaultAV]
  [atTimeLink(concept("B"), timeIntervalNode(4, 9)), stv(0.9, 0.8), defaultAV]
  [implication(concept("A"), concept("B")), stv(0.8, 0.7), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS:AtomSpace, attraction(concept("A"), concept("B"))) == true .

*** Temporal simultaneous: creates similarity link
search [1] in OC-TEMPORAL-REASONING :
  [atTimeLink(concept("X"), timeIntervalNode(5, 10)), stv(0.8, 0.7), defaultAV]
  [atTimeLink(concept("Y"), timeIntervalNode(5, 10)), stv(0.8, 0.7), defaultAV]
=>+ AS:AtomSpace
such that
  hasAtom(AS:AtomSpace, similarity(concept("X"), concept("Y"))) == true .

*** =================================================================
*** GHOST/PSI: additional accessors and action searches
*** =================================================================

load ghost-psi.maude

red in OC-OPENPSI-DEMANDS : demandTarget(psiDemand("energy", 0.8, 0.9)) .
*** expect: 0.9

red in OC-OPENPSI-DEMANDS : modName(psiMod("activation", 0.5)) .
*** expect: "activation"

red in OC-OPENPSI-DEMANDS : modLevel(psiMod("activation", 0.5)) .
*** expect: 0.5

*** rulesForDemand: no matching demand returns empty
red in OC-OPENPSI-RULES :
  psiRuleCount(rulesForDemand(
    psiRule("r1", concept("hungry"), concept("eat"), "energy", 0.9) ;;
    psiRule("r2", concept("danger"), concept("flee"), "safety", 0.8),
    "affiliation"
  )) .
*** expect: 0

*** rulesForDemand: multiple matching rules are all returned
red in OC-OPENPSI-RULES :
  psiRuleCount(rulesForDemand(
    psiRule("r1", concept("hungry"), concept("eat"), "energy", 0.9) ;;
    psiRule("r2", concept("thirsty"), concept("drink"), "energy", 0.7),
    "energy"
  )) .
*** expect: 2

*** PsiRule accessors
red in OC-OPENPSI-RULES :
  prName(psiRule("r1", concept("ctx"), concept("act"), "energy", 0.9)) .
*** expect: "r1"

red in OC-OPENPSI-RULES :
  prContext(psiRule("r1", concept("ctx"), concept("act"), "energy", 0.9)) .
*** expect: concept("ctx")

red in OC-OPENPSI-RULES :
  prAction(psiRule("r1", concept("ctx"), concept("act"), "energy", 0.9)) .
*** expect: concept("act")

red in OC-OPENPSI-RULES :
  prDemand(psiRule("r1", concept("ctx"), concept("act"), "energy", 0.9)) .
*** expect: "energy"

red in OC-OPENPSI-RULES :
  prWeight(psiRule("r1", concept("ctx"), concept("act"), "energy", 0.9)) .
*** expect: 0.9

*** Ghost rule accessors
red in OC-GHOST :
  grName(ghostRule("hello", responder,
         (concept("hi"), nil), concept("resp"), "greetings")) .
*** expect: "hello"

*** Psi demand increase: urgency rises toward target
search [1] in OC-OPENPSI-ENGINE :
  psiState(
    emptyAS,
    psiDemand("energy", 0.3, 0.9) ;; emptyDemands,
    emptyMods,
    emptyPsiRules,
    emptyGhostRules,
    "topic1",
    0)
=>+ PS:PsiState
such that psiCycle(PS:PsiState) == 1 .

*** Ghost gambit: proactive utterance added to AtomSpace
search [1] in OC-OPENPSI-ENGINE :
  psiState(
    emptyAS,
    emptyDemands,
    emptyMods,
    emptyPsiRules,
    ghostRule("g", gambit, nil, concept("hello-world"), "greetings") ;;
    emptyGhostRules,
    "greetings",
    0)
=>+ PS:PsiState
such that
  hasAtom(psiAS(PS:PsiState),
          evaluation(predicate("say"), (concept("hello-world"), nil))) == true .

*** =================================================================
