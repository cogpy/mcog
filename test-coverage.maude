load attention-value.maude

red in OC-ATTENTION-VALUE : getLTI(av(500, 100, false)) .
*** expect: 100

red in OC-ATTENTION-VALUE : getVLTI(av(500, 100, true)) .
*** expect: true

red in OC-ATTENTION-VALUE : getVLTI(av(500, 100, false)) .
*** expect: false

red in OC-ATTENTION-VALUE : decSTI(av(500, 100, false), 50) .
*** expect: av(450, 100, false)

red in OC-ATTENTION-VALUE : incLTI(av(500, 100, false), 20) .
*** expect: av(500, 120, false)

red in OC-ATTENTION-VALUE : decLTI(av(500, 100, false), 30) .
*** expect: av(500, 70, false)

*** setVLTI: identity case (matching VLTI)
red in OC-ATTENTION-VALUE : setVLTI(av(500, 100, true), true) .
*** expect: av(500, 100, true)

*** nullAV accessors
red in OC-ATTENTION-VALUE : getSTI(nullAV) .
*** expect: 0

red in OC-ATTENTION-VALUE : getLTI(nullAV) .
*** expect: 0

red in OC-ATTENTION-VALUE : getVLTI(nullAV) .
*** expect: false

red in OC-ATTENTION-VALUE : totalImportance(nullAV) .
*** expect: 0

red in OC-ATTENTION-VALUE : inAttentionalFocus(nullAV, 0) .
*** expect: false

red in OC-ATTENTION-VALUE : getSTI(defaultAV) .
*** expect: 0

red in OC-ATTENTION-VALUE : getLTI(defaultAV) .
*** expect: 0

*** =================================================================
*** ATOM SPACE: removeAtom, setTV, setAV, getAV, edge cases
*** =================================================================

load atom-space.maude

red in OC-ATOM-SPACE : ocSize(emptyAS) .
*** expect: 0

red in OC-ATOM-SPACE :
  ocSize(
    removeAtom(
      addAtom(
        addAtom(emptyAS, concept("cat"), stv(1.0, 0.9)),
        concept("dog"), stv(0.8, 0.7)),
      concept("cat")
    )
  ) .
*** expect: 1

red in OC-ATOM-SPACE :
  hasAtom(
    removeAtom(
      addAtom(emptyAS, concept("cat"), stv(1.0, 0.9)),
      concept("cat")
    ),
    concept("cat")
  ) .
*** expect: false

red in OC-ATOM-SPACE :
  getAV(
    [concept("cat"), stv(1.0, 0.9), av(100, 50, false)],
    concept("cat")
  ) .
*** expect: av(100, 50, false)

red in OC-ATOM-SPACE : getAV(emptyAS, concept("cat")) .
*** expect: nullAV

red in OC-ATOM-SPACE :
  getTV(
    setTV(
      addAtom(emptyAS, concept("cat"), stv(0.8, 0.9)),
      concept("cat"),
      stv(0.5, 0.6)
    ),
    concept("cat")
  ) .
*** expect: stv(0.5, 0.6)

red in OC-ATOM-SPACE :
  getAV(
    setAV(
      [concept("cat"), stv(1.0, 0.9), av(100, 50, false)],
      concept("cat"),
      av(200, 100, true)
    ),
    concept("cat")
  ) .
*** expect: av(200, 100, true)

red in OC-ATOM-SPACE : getTV(emptyAS, concept("missing")) .
*** expect: nullTV

*** addAtom without explicit TV uses defaultTV
red in OC-ATOM-SPACE :
  getTV(addAtom(emptyAS, concept("cat")), concept("cat")) .
*** expect: stv(1.0, 0.0)

*** getName for various node types
red in OC-ATOM-SPACE : getName(predicate("is-a")) .
*** expect: "is-a"

red in OC-ATOM-SPACE : getName(anchor("main-anchor")) .
*** expect: "main-anchor"

red in OC-ATOM-SPACE : getName(variable("X")) .
*** expect: "X"

red in OC-ATOM-SPACE : getName(schema("add-schema")) .
*** expect: "add-schema"

red in OC-ATOM-SPACE : getName(number("42")) .
*** expect: "42"

